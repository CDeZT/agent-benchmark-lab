{
  "id": "frontend-visual",
  "title": "Repair frontend status rendering",
  "instruction": "Fix the generated status page so it contains a visible h1 title, a status element with text PASS, and no placeholder text. This seed task represents future browser and visual verification work.",
  "capabilities": ["frontend_visual", "visual_verification", "bugfix"],
  "domains": ["frontend", "fullstack"],
  "difficulty": "medium",
  "difficulty_rationale": "Requires reading markup and satisfying both functional and static visual evidence checks.",
  "provenance": {"type": "custom_seed", "source": "agent-benchmark project-owned task corpus"},
  "workspace": "workspace",
  "test_command": ["python3", "test_page.py"],
  "hidden_test_command": ["python3", "test_hidden_page.py"],
  "protected_paths": ["test_page.py"],
  "process_checks": [
    {
      "type": "file_changed",
      "dimension": "execution_quality",
      "path": "index.html"
    },
    {
      "type": "instruction_match",
      "dimension": "intent_understanding",
      "expected_changed_files": ["index.html"]
    }
  ],
  "visual_checks": [
    {
      "type": "html_selector_text",
      "path": "index.html",
      "selector": "h1",
      "text": "System Status"
    },
    {
      "type": "html_selector_text",
      "path": "index.html",
      "selector": "#status",
      "text": "PASS"
    },
    {
      "type": "html_not_contains_text",
      "path": "index.html",
      "text": "TODO"
    },
    {
      "type": "browser_screenshot",
      "path": "index.html",
      "viewport": {"width": 800, "height": 600},
      "required_selectors": ["h1", "#status"],
      "min_non_background_pixels": 200,
      "min_channel_stddev": 2.0
    }
  ]
}
