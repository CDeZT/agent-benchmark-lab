#!/usr/bin/env bash
# Friendly macOS launcher for one full single-harness benchmark experiment.
set -uo pipefail

# Resolve symlinks so `agent-benchmark` can be installed in ~/.local/bin
# while keeping the repository root as the execution directory.
SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
SOURCE="$(cd -P "$(dirname "$SOURCE")" && pwd)/$(basename "$SOURCE")"
ROOT="$(cd -P "$(dirname "$SOURCE")" && pwd)"
CALLER_DIR="$(pwd -P)"
cd "$ROOT"

usage() {
  cat <<'EOF'
Usage: ./benchmark [adapter] [suite]

Install a short command once:
  ./benchmark install

Then create a result folder, enter it, and run:
  agent-benchmark claude-code

Runs a complete benchmark with live progress, refreshes the dashboard, and
opens it on macOS. Live state is saved as suite-*/live_status.json.

Examples:
  ./benchmark claude-code
  ./benchmark opencode hard-discrimination
  AGENT_BENCH_RESULTS_DIR="$HOME/Documents/MyResults" ./benchmark codex

Defaults:
  adapter: claude-code
  suite: comprehensive-screening-v1
  repetitions: 3
  budget profile: stress
  results directory: the current directory (when called outside this repo)
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "install" ]]; then
  INSTALL_DIR="$HOME/.local/bin"
  INSTALL_PATH="$INSTALL_DIR/agent-benchmark"
  mkdir -p "$INSTALL_DIR"
  ln -sfn "$SOURCE" "$INSTALL_PATH"
  echo "Installed: $INSTALL_PATH"
  if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
    echo "Add this directory to PATH before using the short command: $INSTALL_DIR"
  fi
  exit 0
fi

ADAPTER="${1:-claude-code}"
SUITE="${2:-${AGENT_BENCH_SUITE:-comprehensive-screening-v1}}"
REPETITIONS="${AGENT_BENCH_REPETITIONS:-3}"
BUDGET_PROFILE="${AGENT_BENCH_BUDGET_PROFILE:-stress}"
# A command launched from a user-created directory should keep every artifact
# there. Running ./benchmark inside the repository retains the conventional
# ignored runs/ location instead of polluting the source tree root.
if [[ "$CALLER_DIR" == "$ROOT" ]]; then
  DEFAULT_RESULTS_DIR="$ROOT/runs"
else
  DEFAULT_RESULTS_DIR="$CALLER_DIR"
fi
RESULTS_DIR="${AGENT_BENCH_RESULTS_DIR:-$DEFAULT_RESULTS_DIR}"
LABEL="${AGENT_BENCH_LABEL:-${ADAPTER}-current-default}"

mkdir -p "$RESULTS_DIR"
LAUNCHER_LOG_DIR="$RESULTS_DIR/.agent-benchmark-launcher"
mkdir -p "$LAUNCHER_LOG_DIR"

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  BOLD=$'\033[1m'
  CYAN=$'\033[36m'
  DIM=$'\033[2m'
  RESET=$'\033[0m'
else
  BOLD=""
  CYAN=""
  DIM=""
  RESET=""
fi

printf '\n%s%sAgent Benchmark Lab%s\n' "$BOLD" "$CYAN" "$RESET"
printf '  %sHarness%s   %s\n' "$DIM" "$RESET" "$ADAPTER"
printf '  %sCohort%s    %s\n' "$DIM" "$RESET" "$SUITE"
printf '  %sRepeats%s   %s\n' "$DIM" "$RESET" "$REPETITIONS"
printf '  %sResults%s   %s\n\n' "$DIM" "$RESET" "$RESULTS_DIR"

printf '%sChecking environment...%s\n' "$DIM" "$RESET"
if ! PYTHONPATH=src python3 -m agent_benchmark.cli.main doctor > "$LAUNCHER_LOG_DIR/doctor.log" 2>&1; then
  printf '%sEnvironment check failed. Details:%s\n' "$BOLD" "$RESET"
  sed -n '1,200p' "$LAUNCHER_LOG_DIR/doctor.log"
  exit 1
fi
printf '  %sready%s  details: %s\n' "$CYAN" "$RESET" "$LAUNCHER_LOG_DIR/doctor.log"
printf '%sChecking cohort readiness...%s\n' "$DIM" "$RESET"
if ! PYTHONPATH=src python3 -m agent_benchmark.cli.main preflight-matrix \
  --suite "$SUITE" \
  --adapters "$ADAPTER" \
  --models unspecified \
  --budget-profiles "$BUDGET_PROFILE" \
  --repetitions "$REPETITIONS" > "$LAUNCHER_LOG_DIR/preflight.log" 2>&1; then
  printf '%sCohort preflight failed. Details:%s\n' "$BOLD" "$RESET"
  sed -n '1,200p' "$LAUNCHER_LOG_DIR/preflight.log"
  exit 1
fi
printf '  %sready%s  details: %s\n' "$CYAN" "$RESET" "$LAUNCHER_LOG_DIR/preflight.log"

run_status=0
printf '%sStarting benchmark...%s\n' "$DIM" "$RESET"
PYTHONPATH=src python3 -m agent_benchmark.cli.main run-suite \
  --suite "$SUITE" \
  --adapter "$ADAPTER" \
  --model unspecified \
  --budget-profile "$BUDGET_PROFILE" \
  --repetitions "$REPETITIONS" \
  --label "$LABEL" \
  --runs-dir "$RESULTS_DIR" \
  --summary || run_status=$?

PYTHONPATH=src python3 -m agent_benchmark.cli.main dashboard \
  --runs-dir "$RESULTS_DIR" \
  --output-dir "$RESULTS_DIR/dashboard" > "$LAUNCHER_LOG_DIR/dashboard.log" 2>&1 || true

DASHBOARD="$RESULTS_DIR/dashboard/index.html"
if [[ -f "$DASHBOARD" ]]; then
  printf '\n%sDashboard%s  %s\n' "$BOLD" "$RESET" "$DASHBOARD"
  if [[ "${AGENT_BENCH_OPEN_DASHBOARD:-1}" != "0" ]] && command -v open >/dev/null 2>&1; then
    open "$DASHBOARD"
  fi
fi

exit "$run_status"
